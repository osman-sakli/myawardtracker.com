# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
# The Stripe secret/webhook values are optional for the first apply — they
# default to "REPLACE_ME" placeholders and are updated directly in Secrets
# Manager out-of-band (see README).

project     = "myawardtracker"
environment = "prod"
aws_region  = "us-east-1"
domain_name = "myawardtracker.com"

# Stripe — only the price id is set here; the secret key and webhook secret
# are written straight into Secrets Manager, never into tfvars.
# stripe_price_individual = "price_..."

# Cost guardrail: set alert_email to enable an AWS Budget at this monthly cap.
# alert_email        = "you@example.com"
# budget_monthly_usd = 20
